[Example OF CTE]

WITH CTE_Example as
(
Select AVG(Salary) avg_sal
FROM EmployeeDemographics dem
JOIN EmployeeSalary sal
 ON dem.EmployeeID = sal.EmployeeID
GROUP BY gender
)
SELECT AVG(avg_sal)
FROM CTE_Example
;

xxx==============================================================================================================xxx

[Example OF subquery]

SELECT AVG(avg_sal)
FROM (
Select AVG(Salary) avg_sal
FROM EmployeeDemographics dem
JOIN EmployeeSalary sal
 ON dem.EmployeeID = sal.EmployeeID
GROUP BY gender
) example_subquery
;

